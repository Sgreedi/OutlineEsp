-- PlayerOutlines LocalScript
-- Place this inside StarterPlayerScripts or StarterCharacterScripts

local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

-- Settings (customize these!)
local OUTLINE_COLOR   = Color3.fromRGB(0, 255, 255)        -- Aqua outline color
local FILL_COLOR      = Color3.fromRGB(0, 255, 255)        -- Aqua fill color
local FILL_OPACITY    = 0                                   -- 0 = transparent fill, 1 = solid
local OUTLINE_OPACITY = 1                                   -- 0 = invisible, 1 = fully visible
local SHOW_ON_SELF    = false                               -- Set true to also outline yourself
local DEPTH_MODE      = Enum.HighlightDepthMode.AlwaysOnTop -- Shows through walls; use "Occluded" to hide behind walls
local REFRESH_RATE    = 5                                   -- Seconds between each outline refresh

-- Applies a Highlight to a character model
local function applyOutline(character)
	if character:FindFirstChildOfClass("Highlight") then return end

	local highlight = Instance.new("Highlight")
	highlight.OutlineColor        = OUTLINE_COLOR
	highlight.FillColor           = FILL_COLOR
	highlight.FillTransparency    = FILL_OPACITY == 0 and 1 or (1 - FILL_OPACITY)
	highlight.OutlineTransparency = 1 - OUTLINE_OPACITY
	highlight.DepthMode           = DEPTH_MODE
	highlight.Adornee             = character
	highlight.Parent              = character
end

-- Refreshes the Highlight with no flicker (new one created before old one is destroyed)
local function refreshOutline(character)
	local old = character:FindFirstChildOfClass("Highlight")

	local highlight = Instance.new("Highlight")
	highlight.OutlineColor        = OUTLINE_COLOR
	highlight.FillColor           = FILL_COLOR
	highlight.FillTransparency    = FILL_OPACITY == 0 and 1 or (1 - FILL_OPACITY)
	highlight.OutlineTransparency = 1 - OUTLINE_OPACITY
	highlight.DepthMode           = DEPTH_MODE
	highlight.Adornee             = character
	highlight.Parent              = character

	-- Destroy the old one AFTER the new one is already parented
	if old then old:Destroy() end
end

-- Removes the Highlight from a character
local function removeOutline(character)
	local h = character:FindFirstChildOfClass("Highlight")
	if h then h:Destroy() end
end

-- Handles a player being added to the game
local function onPlayerAdded(player)
	if not SHOW_ON_SELF and player == localPlayer then return end

	if player.Character then
		applyOutline(player.Character)
	end

	player.CharacterAdded:Connect(function(character)
		task.wait(0.1)
		applyOutline(character)
	end)

	player.CharacterRemoving:Connect(function(character)
		removeOutline(character)
	end)
end

-- Hook up all current and future players
for _, player in ipairs(Players:GetPlayers()) do
	onPlayerAdded(player)
end

Players.PlayerAdded:Connect(onPlayerAdded)

-- Remove outlines when a player leaves
Players.PlayerRemoving:Connect(function(player)
	if player.Character then
		removeOutline(player.Character)
	end
end)

-- Flicker-free refresh loop
task.spawn(function()
	while true do
		task.wait(REFRESH_RATE)
		for _, player in ipairs(Players:GetPlayers()) do
			if not SHOW_ON_SELF and player == localPlayer then continue end
			if player.Character then
				refreshOutline(player.Character)
			end
		end
	end
end)
