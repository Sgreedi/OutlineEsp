-- PlayerOutlines (LocalScript)
-- Place this inside StarterPlayerScripts
-- Uses Highlight to draw a smooth outline around other players' characters (not yourself)
 
local Players = game:GetService("Players")
 
local localPlayer = Players.LocalPlayer
 
-- =====================
--   Customize here
-- =====================
local OUTLINE_COLOR        = Color3.fromRGB(0, 120, 255)  -- Color of the outline glow
local OUTLINE_TRANSPARENCY = 0                             -- 0 = fully visible, 1 = invisible
local FILL_TRANSPARENCY    = 1                             -- 1 = outline only (no fill), 0 = solid fill
-- =====================
 
local highlights = {}  -- [Player] = Highlight instance
 
local function removeHighlight(player)
	if highlights[player] then
		highlights[player]:Destroy()
		highlights[player] = nil
	end
end
 
local function applyHighlight(character)
	local highlight = Instance.new("Highlight")
	highlight.OutlineColor        = OUTLINE_COLOR
	highlight.OutlineTransparency = OUTLINE_TRANSPARENCY
	highlight.FillTransparency    = FILL_TRANSPARENCY
	highlight.Adornee             = character
	highlight.Parent              = character
	return highlight
end
 
local function onCharacterAdded(player, character)
	removeHighlight(player)
	character:WaitForChild("HumanoidRootPart", 10)
	highlights[player] = applyHighlight(character)
end
 
local function onPlayerAdded(player)
	if player == localPlayer then return end  -- Skip yourself
 
	player.CharacterAdded:Connect(function(character)
		onCharacterAdded(player, character)
	end)
 
	if player.Character then
		onCharacterAdded(player, player.Character)
	end
end
 
local function onPlayerRemoving(player)
	removeHighlight(player)
end
 
Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(onPlayerRemoving)
 
for _, player in ipairs(Players:GetPlayers()) do
	onPlayerAdded(player)
end
 
